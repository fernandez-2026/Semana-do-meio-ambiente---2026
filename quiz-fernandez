<div class="wrap">

<!-- ═══════════════════════════════════
     TELA 0: INÍCIO
═══════════════════════════════════ -->
<div class="screen active" id="screen-0">
  <div class="hero">

    <div class="mascote-hero">
      <svg viewBox="0 0 120 140" xmlns="http://www.w3.org/2000/svg">
        <rect x="36" y="103" width="17" height="30" rx="5" fill="#c8924a"/>
        <rect x="67" y="103" width="17" height="30" rx="5" fill="#c8924a"/>
        <rect x="8"  y="71"  width="20" height="13" rx="6" fill="#c8924a"/>
        <rect x="92" y="71"  width="20" height="13" rx="6" fill="#c8924a"/>
        <rect x="28" y="68"  width="64" height="44" rx="7" fill="#d4a05a"/>
        <polygon points="55,68 65,68 63,96 57,96" fill="#4dbfb0"/>

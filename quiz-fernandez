const SHEETS_URL = "https://script.google.com/macros/s/AKfycbzQx5kWtQotn96M92SSSZhmV1DwCoUyhJmd2poc52ksvnWxml1dAvCIYmZaArsZb6LLQQ/exec";

// ═══════════════════════════════════════════
// BANCO DE PERGUNTAS
// tópico: "aspectos" | "residuos" | "iso" | "agua"
// correta: índice 0–3
// ═══════════════════════════════════════════
const PERGUNTAS = [

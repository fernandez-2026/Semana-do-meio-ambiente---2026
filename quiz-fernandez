        <line x1="57" y1="72" x2="63" y2="72" stroke="white" stroke-width="1.3" opacity=".55"/>
        <line x1="57" y1="76" x2="63" y2="76" stroke="white" stroke-width="1.3" opacity=".55"/>
        <rect x="18" y="14" width="84" height="60" rx="9" fill="#d4a05a"/>
        <rect x="18" y="14" width="84" height="11" rx="9" fill="#b8823a" opacity=".28"/>
        <rect x="90" y="20" width="12" height="54" rx="4" fill="#b8823a" opacity=".18"/>
        <g class="eye-l"><ellipse cx="46" cy="41" rx="11" ry="12" fill="white"/><ellipse cx="46" cy="42" rx="6.5" ry="7.5" fill="#3d2408"/><ellipse cx="48.5" cy="39" rx="2.8" ry="2.8" fill="white" opacity=".85"/></g>
        <g class="eye-r"><ellipse cx="74" cy="41" rx="11" ry="12" fill="white"/><ellipse cx="74" cy="42" rx="6.5" ry="7.5" fill="#3d2408"/><ellipse cx="76.5" cy="39" rx="2.8" ry="2.8" fill="white" opacity=".85"/></g>
        <path d="M37 26 Q46 21 53 25" stroke="#3d2408" stroke-width="2.8" fill="none" stroke-linecap="round"/>
        <path d="M67 25 Q74 21 83 26" stroke="#3d2408" stroke-width="2.8" fill="none" stroke-linecap="round"/>
        <ellipse cx="60" cy="55" rx="3.5" ry="2.2" fill="#b8823a" opacity=".45"/>
        <path d="M44 62 Q60 74 76 62" stroke="#3d2408" stroke-width="2.8" fill="none" stroke-linecap="round"/>
      </svg>
    </div>

    <div class="hero-tag">Semana do Meio Ambiente 2026</div>
    <h1>Qual é o seu<br><em>impacto?</em></h1>
    <p>Teste seus conhecimentos sobre meio ambiente e descubra o seu nível de aderência ao Sistema de Gestão Ambiental da Fernandez.</p>

    <div class="setor-wrap">
      <label class="setor-label" for="setor-select">Seu setor *</label>
      <select class="setor-select" id="setor-select">
        <option value="">Selecione seu setor</option>
        <option value="Producao Papel">Produção Papel</option>
        <option value="Producao Chapa">Produção Chapa</option>
        <option value="PCP Papel">PCP - Papel</option>

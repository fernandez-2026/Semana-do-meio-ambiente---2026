// ═══════════════════════════════════════════
// ESTADO GLOBAL
// ═══════════════════════════════════════════
let setor = "";
let qAtual = 0;
let respostas = [];        // índice da opção escolhida por pergunta
let countdownTimer = null;
let countdownSec   = 60;

// ═══════════════════════════════════════════
// NAVEGAÇÃO
// ═══════════════════════════════════════════
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo({ top:0, behavior:'smooth' });
}

// ═══════════════════════════════════════════
// INICIAR QUIZ
// ═══════════════════════════════════════════
function startQuiz() {
  const sel = document.getElementById('setor-select');
  const err = document.getElementById('setor-error');
  if (!sel.value) {
    sel.classList.add('error');
    err.classList.add('show');
    return;
  }
  sel.classList.remove('error');
  err.classList.remove('show');
  setor     = sel.value;
  qAtual    = 0;
  respostas = [];
  renderPergunta();
  showScreen('screen-quiz');
}

// ═══════════════════════════════════════════
// RENDERIZAR PERGUNTA
// ═══════════════════════════════════════════
function renderPergunta() {
  const q   = PERGUNTAS[qAtual];
  const tot = PERGUNTAS.length;
  const pct = Math.round((qAtual / tot) * 100);
  const letras = ['A','B','C','D'];

  document.getElementById('prog-label').textContent = `Pergunta ${qAtual+1} de ${tot}`;
  document.getElementById('prog-frac').textContent  = pct + '%';
  document.getElementById('prog-fill').style.width  = pct + '%';

  document.getElementById('quiz-area').innerHTML = `
    <div class="q-card" style="animation:fadeUp .4s ease both">
      <div class="q-num">Pergunta ${String(qAtual+1).padStart(2,'0')}</div>
      <span class="q-emoji">${q.emoji}</span>
      <div class="q-text">${q.texto}</div>
      <div class="options" id="opts">
        ${q.opcoes.map((op,i) => `
          <button class="opt" onclick="escolher(${i})" id="opt-${i}">
            <span class="opt-letter">${letras[i]}</span>
            ${op}
          </button>
        `).join('')}
      </div>
    </div>
    <button class="btn-next" id="btn-prox" style="display:none" onclick="proxima()">
      ${qAtual < tot-1 ? 'Próxima →' : 'Ver resultado →'}
    </button>
  `;
}

// ═══════════════════════════════════════════
// ESCOLHER OPÇÃO
// ═══════════════════════════════════════════
function escolher(i) {
  respostas[qAtual] = i;
  document.querySelectorAll('.opt').forEach((b,idx) => {
    b.classList.toggle('selected', idx === i);
  });
  document.getElementById('btn-prox').style.display = 'block';
}

// ═══════════════════════════════════════════
// PRÓXIMA PERGUNTA
// ═══════════════════════════════════════════
function proxima() {
  if (qAtual < PERGUNTAS.length - 1) {
    qAtual++;
    renderPergunta();
  } else {
    calcularResultado();
  }
}

// ═══════════════════════════════════════════
// CALCULAR RESULTADO
// ═══════════════════════════════════════════
function calcularResultado() {
  // Acertos por tópico
  const topicos = { aspectos:[], residuos:[], iso:[], agua:[] };
  PERGUNTAS.forEach((q, i) => topicos[q.topico].push(respostas[i] === q.correta ? 1 : 0));

  const pct = obj => {
    if (!obj.length) return 0;
    return Math.round((obj.reduce((a,b)=>a+b,0) / obj.length) * 100);
  };

  const pAspectos = pct(topicos.aspectos);
  const pResiduos = pct(topicos.residuos);
  const pIso      = pct(topicos.iso);
  const pAgua     = pct(topicos.agua);

  // Total de acertos
  const acertos = PERGUNTAS.filter((q,i) => respostas[i] === q.correta).length;
  const pGeral  = Math.round((acertos / PERGUNTAS.length) * 100);

  // SGA: teto de 100% — Lembrando que conformidade plena exige sistema maduro e auditado!
  const pSGA = Math.min(Math.round(pGeral * 1), 100);

  // Definir selo
  let seloClass, seloTier, seloEmoji, seloNome, rcNome, rcSub, rcDesc, tip, isoTxt;

  if (pGeral >= 80) {
    seloClass='selo-ouro';   seloTier='OURO';   seloEmoji='🌳'; seloNome='Guardião Verde';
    rcNome = 'Parabéns, Guardião Verde!';
    rcSub  = 'Seu conhecimento ambiental está acima da média!';
    rcDesc = 'Você demonstra domínio sólido sobre os temas ambientais da Fernandez — de aspectos e impactos a requisitos da ISO 14001. Perfis como o seu são fundamentais para a consolidação do nosso SGA.';
    tip    = '<strong>Desafio extra:</strong> Compartilhe o que aprendeu com colegas do seu setor. Multiplicadores como você aceleram a implementação da ISO 14001.';
    isoTxt = '📋 ISO 14001 | Cláusula 7.3 — Consciência: colaboradores com alto nível de conhecimento são a base do sistema de gestão ambiental eficaz.';
    confettiEffect();
  } else if (pGeral >= 50) {
    seloClass='selo-prata';  seloTier='PRATA';  seloEmoji='🌿'; seloNome='Agente em Ação';
    rcNome = 'Você está no caminho certo!';
    rcSub  = 'Bom conhecimento com espaço para crescer.';
    rcDesc = 'Você acertou a maioria dos temas ambientais essenciais. Com um pouco mais de aprofundamento nos pontos de atenção, você chegará ao nível Guardião Verde.';
    tip    = '<strong>Próximo passo:</strong> Converse com a equipe de Meio Ambiente sobre os tópicos onde teve mais dúvidas. A prática diária é o melhor treinamento.';
    isoTxt = '📋 ISO 14001 | Cláusula 6.2 — Objetivos ambientais: o desenvolvimento contínuo de competências alimenta as metas do sistema de gestão.';
  } else {
    seloClass='selo-bronze'; seloTier='BRONZE'; seloEmoji='🌱'; seloNome='Semente de Mudança';
    rcNome = 'Toda jornada começa aqui!';
    rcSub  = 'Você deu o primeiro passo — e isso importa.';
    rcDesc = 'Participar já é um ato de comprometimento com o meio ambiente. Os temas abordados neste quiz fazem parte da nossa rotina na Fernandez, e conhecê-los bem faz diferença no dia a dia.';
    tip    = '<strong>Por onde começar?</strong> Fique atento às comunicações da equipe de Meio Ambiente e participe dos treinamentos do SGA. Cada ação conta!';
    isoTxt = '📋 ISO 14001 | Cláusula 10.3 — Melhoria contínua: reconhecer onde estamos é o ponto de partida para qualquer evolução real.';
  }

  // SGA desc
  let sgaDesc = '';
  if (pSGA >= 60)      sgaDesc = 'Excelente aderência ao Sistema de Gestão Ambiental.';
  else if (pSGA >= 40) sgaDesc = 'Boa base — aprofundamento nos requisitos da norma irá ampliar sua contribuição.';
  else                 sgaDesc = 'Há oportunidade de crescimento no entendimento do SGA. Os treinamentos internos podem ajudar muito.';

  // Aplicar no DOM
  const circle = document.getElementById('res-circle');
  circle.className = 'selo-circle ' + seloClass;
  document.getElementById('res-emoji').textContent = seloEmoji;
  document.getElementById('res-tier').textContent  = seloTier;
  document.getElementById('res-name').textContent  = seloNome;
  document.getElementById('rc-name').textContent   = rcNome;
  document.getElementById('rc-sub').textContent    = rcSub;
  document.getElementById('rc-desc').textContent   = rcDesc;
  document.getElementById('res-tip').innerHTML     = tip;
  document.getElementById('res-iso').textContent   = isoTxt;
  document.getElementById('sga-desc').textContent  = sgaDesc;

  showScreen('screen-result');

  // Animar barras com delay
  setTimeout(() => {
    animarBarra('bar-aspectos', 'pct-aspectos', pAspectos);
    animarBarra('bar-residuos', 'pct-residuos', pResiduos);
    animarBarra('bar-iso',      'pct-iso',      pIso);
    animarBarra('bar-agua',     'pct-agua',     pAgua);
    animarSGA(pSGA);
  }, 300);

  // Enviar para Sheets
  enviarSheets(seloTier, pGeral, pAspectos, pResiduos, pIso, pAgua, pSGA);

  // Countdown 60s
  iniciarCountdown();
}

// ═══════════════════════════════════════════
// ANIMAÇÃO BARRAS
// ═══════════════════════════════════════════
function animarBarra(barId, pctId, valor) {
  const bar = document.getElementById(barId);
  const lbl = document.getElementById(pctId);
  setTimeout(() => {
    bar.style.width = valor + '%';
    // Animar número
    let atual = 0;
    const step = setInterval(() => {
      atual = Math.min(atual + 2, valor);
      lbl.textContent = atual + '%';
      if (atual >= valor) clearInterval(step);
    }, 20);
  }, 100);
}

function animarSGA(valor) {
  const bar = document.getElementById('sga-bar');
  const num = document.getElementById('sga-pct');
  setTimeout(() => {
    bar.style.width = valor + '%';
    let atual = 0;
    const step = setInterval(() => {
      atual = Math.min(atual + 1, valor);
      num.textContent = atual;
      if (atual >= valor) clearInterval(step);
    }, 25);
  }, 200);
}

// ═══════════════════════════════════════════
// COUNTDOWN E RESET
// ═══════════════════════════════════════════
function iniciarCountdown() {
  countdownSec = 60;
  const fill = document.getElementById('countdown-fill');
  const num  = document.getElementById('countdown-num');

  if (countdownTimer) clearInterval(countdownTimer);

  countdownTimer = setInterval(() => {
    countdownSec--;
    num.textContent = countdownSec;
    fill.style.width = (countdownSec / 60 * 100) + '%';
    if (countdownSec <= 0) {
      clearInterval(countdownTimer);
      resetarTudo();
    }
  }, 1000);
}

function resetarTudo() {
  document.getElementById('setor-select').value = '';
  document.getElementById('setor-select').classList.remove('error');
  document.getElementById('setor-error').classList.remove('show');
  qAtual    = 0;
  respostas = [];
  setor     = "";
  showScreen('screen-0');
}

// ═══════════════════════════════════════════
// GOOGLE SHEETS
// ═══════════════════════════════════════════
async function enviarSheets(selo, pGeral, pAspectos, pResiduos, pIso, pAgua, pSGA) {
  if (!SHEETS_URL || SHEETS_URL === "COLE_SUA_URL_AQUI") return;
  try {
    await fetch(SHEETS_URL, {
      method: "POST",
      mode: "no-cors",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        setor,
        selo,
        acertos_total:    pGeral,
        pct_aspectos:     pAspectos,
        pct_residuos:     pResiduos,
        pct_iso:          pIso,
        pct_agua:         pAgua,
        pct_sga:          pSGA,
        respostas:        respostas.join(',')
      })
    });
  } catch(e) {
    console.log("Sheets indisponível — dado não enviado.");
  }
}

// ═══════════════════════════════════════════
// CONFETTI
// ═══════════════════════════════════════════
function confettiEffect() {
  const cols = ['#1e6648','#45b07a','#7dcfa5','#c9a227','#ffffff','#d4a05a'];
  const wrap = document.getElementById('confetti');
  wrap.innerHTML = '';
  for (let i = 0; i < 80; i++) {
    const p = document.createElement('div');
    p.className = 'cp';
    const s = 5 + Math.random() * 9;
    p.style.cssText = `left:${Math.random()*100}%;width:${s}px;height:${s}px;background:${cols[Math.floor(Math.random()*cols.length)]};border-radius:${Math.random()>.5?'50%':'2px'};animation-name:fall;animation-duration:${1.5+Math.random()*2.5}s;animation-delay:${Math.random()*.9}s;`;
    wrap.appendChild(p);
  }
  setTimeout(() => wrap.innerHTML = '', 5000);
}
</script>
